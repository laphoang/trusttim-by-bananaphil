# Crawler-only env (separate from the app's root .env.example — the Next.js app never uses AWS).
# boto3 reads AWS_* from this standard chain automatically.
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1

# Target S3 bucket (must already exist). Objects land under S3_PREFIX/crawl_date=YYYY-MM-DD/.
S3_BUCKET=your-bucket-name
S3_PREFIX=raw-crawl

# Crawl bounds. No robots.txt/sitemap exists on the site, so depth + page caps are the only bound.
CRAWL_BASE_URL=https://benhvientimhanoi.vn
CRAWL_MAX_DEPTH=3
CRAWL_MAX_PAGES=200
MIN_CONTENT_CHARS=200

# Optional — only needed if you switch crawl.py to an LLM-based extraction/filter strategy
# (e.g. crawl4ai's LLMContentFilter). Unused by the current PruningContentFilter-based script.
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
