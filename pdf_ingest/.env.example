# S3 (standard boto3 chain — same convention as the crawler, can be the same bucket).
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1

S3_BUCKET=your-bucket-name
S3_INPUT_PREFIX=raw-pdf
S3_OUTPUT_PREFIX=cleaned-pdf

# Whole-document native-vs-scanned decision threshold (average extractable chars/page).
MIN_CHARS_PER_PAGE=40
