# FPT AI Factory — one OpenAI-compatible base URL + key for all three models.
# See hackathon_docs/guide/llm_api_example.md and TrustTim_Implementation-Spec.md §2.
API_BASE_URL=https://mkp-api.fptcloud.com
API_KEY=your-fpt-api-key

# Swap any of these to move models/providers — env-var change, not a rewrite.
LLM_MODEL=gpt-oss-20b
EMBEDDING_MODEL=Vietnamese_Embedding
RERANKER_MODEL=bge-reranker-v2-m3

# Must match lib/db/schema.sql's kb_chunks.embedding vector(N). Confirm live against the
# embeddings endpoint before changing (Implementation Spec §1.3).
EMBEDDING_DIM=1024

# Postgres with the pgvector extension available (Supabase/Neon free tier for the demo,
# or local docker: postgres://postgres:postgres@localhost:5432/trusttim).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trusttim
