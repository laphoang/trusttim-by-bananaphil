# S3 (standard boto3 chain — same convention as pdf_ingest/crawler, can be the same bucket).
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1

S3_BUCKET=your-bucket-name
S3_CHUNK_INPUT_PREFIX=pdf/cleaned-pdf
S3_CHUNK_OUTPUT_PREFIX=knowledge-base/pdf-chunks

# Retrieval chunk sizing (BGE-M3 / FPT vietnamese-embedding caps at 2048 tokens — 500 is comfortable).
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=100

# Single topic label applied to every chunk in a run (all current cleaned PDFs are price lists).
CHUNK_TOPIC=bhyt_pricing
