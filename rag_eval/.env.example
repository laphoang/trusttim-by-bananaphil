# LLM-as-judge (RAGAS faithfulness / answer relevance / context precision & recall).
OPENAI_API_KEY=your-openai-api-key
JUDGE_MODEL=gpt-5.5

# FPT AI Factory — embeddings, used by RAGAS's answer-relevance/context metrics (same convention
# as kb_ingest/.env.example and the root .env.example; production parity for Vietnamese text).
API_BASE_URL=https://mkp-api.fptcloud.com
API_KEY=your-fpt-api-key
EMBEDDING_MODEL=Vietnamese_Embedding
EMBEDDING_DIM=1024

# Inputs (defaults shown — override only if you moved the files).
GOLDEN_FILE=../data/eval/golden-answers.json
RUNS_FILE=../data/eval/runs/latest.jsonl
